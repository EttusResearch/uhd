#
# Description:
#   Clock definition constraints for X420 200 MHz BW type images
#

# Data clocks: Generated by the MMCM, used for data paths between the RFDC output and RFNoC.
# The RFDC block diagram is set up for the maximum required clock frequencies (rfdc_clk_1x @ ~320 MHz),
# which are used in the 1000 MHz bitfile.
# This is not required for the 200 MHz bitfile, hence we multiply the output clock divider values by 5
# to allow Vivado to auto-derive the correct clock periods.

set data_clock_mmcm [get_cells -hierarchical -filter { PRIMITIVE_TYPE == CLOCK.PLL.MMCME4_ADV && NAME =~  "*data_clock_mmcm*" }]

set_property -dict [ list \
   CLKOUT1_DIVIDE {20} \
   CLKOUT2_DIVIDE {20} \
   CLKOUT3_DIVIDE {10} \
   CLKOUT4_DIVIDE {10} \
   CLKOUT5_DIVIDE {20} \
   CLKOUT6_DIVIDE {10} \
] $data_clock_mmcm
